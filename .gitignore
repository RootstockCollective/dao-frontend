# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.tool-versions

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env file
.env
.env.local
# Exception: .env.fork should be committed (template for fork environment)
!.env.fork

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log

# PHPStorm
.idea

# Cursor — generated from .workflow via scripts/export-workflow-adapters.sh (local only)
.cursor/

# bun lock file
bun.lockb

#VSCode
.vscode

# Sentry Config File
.env.sentry-build-plugin

# AI workflow — only canonical .workflow/ is committed; adapters generated locally
.claude/
CLAUDE.md
.github/copilot-instructions.md

# Workflow handoff artifacts (local only; used between agents, not needed in repo after merge)
# Retros and devlogs are NOT ignored — we commit them to improve the workflow
.workflow/stories/
.workflow/plans/
.workflow/reviews/
.workflow/qa-reports/
