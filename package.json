    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-storybook": "10.2.10",
    "http-proxy-middleware": "^3.0.5",
    "husky": "9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "16.2.7",
